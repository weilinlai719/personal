---
// src/components/header.astro
const pathname = Astro.url.pathname;

// 判斷目前是否在該頁面
const isAbout = pathname.includes('/about');
const ispost = pathname.includes('/post');
const isarticle = pathname.includes('/article');
---

<header class="navbar">
  <div class="nav-container">
    <div class="nav-logo">
      <a href="/" class="logo-text">Weilin Lai</a>
    </div>
         
    <button class="menu-toggle" id="menuToggle" aria-label="切換選單">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

    <nav class="nav-menu" id="navMenu">
      <div class="nav-links">
        
        <a href="/post/" class:list={['nav-item', 'nav-link', { active: ispost }]}>
          Posts
        </a>
     
        
        <a href="/article/" class:list={['nav-item', 'nav-link', { active: isarticle }]}>
          article
        </a>

        <div class="nav-item dropdown">
          <button class="dropdown-trigger" id="projectsTrigger">
            projects
            <svg class="chevron-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
          
          <div class="dropdown-content">
            <a href="https://weilinlai719.github.io/personal/Taipei101" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🏮 Taipei 101 Fireworks</span>
            </a>
            <a href="https://weilinlai719.github.io/personal/tetris" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🕹️ Tetris Game</span>
            </a>
            <a href="https://weilinlai719.github.io/luckydraw" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🎁 抽獎器</span>
            </a>
            <a href="https://weilinlai719.github.io/personal/flipcard" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🃏 Flip Card (寒假單字)</span>
            </a>
            <a href="https://weilinlai719.github.io/personal/pdfreader" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">📚 PDF Reader</span>
            </a>
            <a href="https://weilinlai719.github.io/earth-science-explore/" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🌎 地科探究</span>
            </a>
          </div>
        </div>

        <a href="/about/" class:list={['nav-item', 'nav-link', { active: isAbout }]}>
          about
        </a>
        
      </div>
    </nav>
  </div>
</header>

<style> 
  /* =======================================================
     ☀️ 桌機版核心樣式 (100% 繼承原版毛玻璃風格)
     ======================================================= */
  .navbar {
    background: var(--header-bg, rgba(255, 255, 255, 0.65));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--shadow-color2, #e5e7eb);
    position: sticky;
    top: 0;
    z-index: 1000;
    padding: 0 20px;
    height: 4rem;
    display: flex;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
  }

  .nav-container {
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }

  .logo-text {
    text-decoration: none;
    color: var(--text-color, #171717);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .nav-links { 
    display: flex; 
    gap: 10px;
    align-items: center;
  }
  
  .nav-item {
    text-decoration: none;
    color: var(--secondary-text-color, #6f6f6f);
    padding: 8px 16px;
    border-radius: 6px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    font-size: 0.95rem;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nav-link {
    text-decoration: none;
    color: inherit;
  }

  .nav-item.active, .nav-link.active { 
    color: var(--text-color, #121213);
    font-weight: 500;
  }

  .nav-item:hover { 
    color: var(--text-color, #000000);
    background: var(--shadow-color2, rgba(0,0,0,0.05));
  }

  .dropdown-trigger {
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
    width: 100%;
    height: 100%;
  }

  .chevron-icon {
    width: 14px;
    height: 14px;
    fill: currentColor;
    transition: transform 0.3s ease;
  }

  .dropdown-content {
    position: absolute;
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    padding: 8px;
    box-sizing: border-box;
    z-index: 99999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
  }

  .dropdown-link {
    display: block;
    color: #6f6f6f;
    padding: 12px 16px;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .link-title {
    font-size: 0.95rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .dropdown-link:hover {
    background-color: #f5f5f5;
    color: #171717;
  }

  /* 📱 手機版漢堡按鈕核心結構 */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 15px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 2000;
  }

  .hamburger-bar {
    width: 100%;
    height: 2px;
    background-color: var(--text-color, #171717);
    border-radius: 2px;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* 🍔 漢堡按鈕變形為精緻 X 效果 */
  .menu-toggle.is-active .hamburger-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-toggle.is-active .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-toggle.is-active .hamburger-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* =======================================================
     💻 電腦版媒體查詢 (min-width: 769px) 懸浮機制
     ======================================================= */
  @media screen and (min-width: 769px) {
    .dropdown {
      position: relative;
    }
    
    .dropdown-content {
      top: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(-10px);
      width: 240px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .dropdown:hover .dropdown-content {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(4px);
    }

    .dropdown:hover .chevron-icon {
      transform: rotate(180deg);
    }
  }

  /* =======================================================
     📱 手機版 RWD 自動適應升級 (max-width: 768px)
     ======================================================= */
  @media screen and (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }

    /* 手機版導覽下拉抽屜選單面板 */
    .nav-menu {
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      background: var(--header-bg, rgba(255, 255, 255, 0.85));
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      border-bottom: 1px solid var(--shadow-color2, #e5e7eb);
      padding: 5px 20px 24px 20px;
      border-radius: 12px;

      /* 預設隱藏 */
      display: none;
      flex-direction: column;
      z-index: 1500;
      max-height: calc(100vh - 4rem);
      overflow-y: auto;
    }

    /* 當漢堡點擊啟用時，強勢轉為顯現狀態 */
    .nav-menu.is-active {
      display: flex !important;
    }

    .nav-links {
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
    }

    .nav-item {
      width: 100%;
      box-sizing: border-box;
      justify-content: space-between;
      padding: 14px 18px;
      font-size: 1.05rem;
    }

    /* 手機版就地手風琴拉開摺疊 */
    .dropdown {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      
    }

    .dropdown-content {
      position: static;
      width: 100%;
      opacity: 1;
      visibility: visible;
      box-shadow: none;
      border: none;
      padding: 4px 0 4px 14px;
      margin-top: 6px;
      border-left: 2px solid #e5e7eb;

      /* 手機預設收合 */
      display: none;
      flex-direction: column;
      gap: 6px;
      transform: none;
    }

    .dropdown-content.is-active {
      display: flex !important;
    }

    .dropdown-link {
      background-color: var(--shadow-color2, rgba(0, 0, 0, 0.02));
      padding: 12px 16px;
    }

    .dropdown-trigger.is-active .chevron-icon {
      transform: rotate(180deg);
    }
  }
</style>

<script>
  // 🔥 【核心修正】將點擊事件處理函數定義在全域範疇，徹底解決 removeEventListener 記憶體位址不一致造成的重疊 bug
  
  function toggleMobileMenu(e: Event) {
    e.stopPropagation();
    const menuToggle = document.getElementById('menuToggle');
    const navMenu = document.getElementById('navMenu');
    
    menuToggle?.classList.toggle('is-active');
    navMenu?.classList.toggle('is-active');
  }

  function handleDropdownToggle(e: Event) {
    if (window.innerWidth > 768) return; // 桌機版回歸 CSS :hover 控管

    e.preventDefault();
    e.stopPropagation();

    const currentTrigger = e.currentTarget as HTMLElement;
    const dropdownContainer = currentTrigger.closest('.dropdown');
    const currentContent = dropdownContainer?.querySelector('.dropdown-content') as HTMLElement | null;

    if (currentContent) {
      const isCurrentlyActive = currentContent.classList.contains('is-active');

      // 關閉其他無關的手機下拉清單
      document.querySelectorAll('.dropdown-content').forEach((c) => {
        if (c !== currentContent) c.classList.remove('is-active');
      });
      document.querySelectorAll('.dropdown-trigger').forEach((t) => {
        if (t !== currentTrigger) t.classList.remove('is-active');
      });

      // 切換當前狀態
      if (isCurrentlyActive) {
        currentContent.classList.remove('is-active');
        currentTrigger.classList.remove('is-active');
      } else {
        currentContent.classList.add('is-active');
        currentTrigger.classList.add('is-active');
      }
    }
  }

  function closeAllMenusSafely(e: MouseEvent) {
    const target = e.target as HTMLElement;
    // 如果使用者點擊的地方不在選單容器內部，全面自動收合
    if (!target.closest('.nav-container')) {
      document.getElementById('menuToggle')?.classList.remove('is-active');
      document.getElementById('navMenu')?.classList.remove('is-active');
      document.querySelectorAll('.dropdown-content').forEach((c) => c.classList.remove('is-active'));
      document.querySelectorAll('.dropdown-trigger').forEach((t) => t.classList.remove('is-active'));
    }
  }

  // 系統集成初始化機制
  function initNavigationSystem() {
    const menuToggle = document.getElementById('menuToggle');
    const dropdownTriggers = document.querySelectorAll('.dropdown-trigger');

    // 1. 強固漢堡按鈕監聽 (先清除防重疊，再掛載)
    if (menuToggle) {
      menuToggle.removeEventListener('click', toggleMobileMenu);
      menuToggle.addEventListener('click', toggleMobileMenu);
    }

    // 2. 強固下拉按鈕監聽
    dropdownTriggers.forEach((trigger) => {
      trigger.removeEventListener('click', handleDropdownToggle);
      trigger.addEventListener('click', handleDropdownToggle);
    });

    // 3. 空白處關閉機制
    document.removeEventListener('click', closeAllMenusSafely);
    document.addEventListener('click', closeAllMenusSafely);
  }

  // 自動因應視窗大小調整清理殘留樣式
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) {
      document.getElementById('menuToggle')?.classList.remove('is-active');
      document.getElementById('navMenu')?.classList.remove('is-active');
      document.querySelectorAll('.dropdown-content').forEach((c) => c.classList.remove('is-active'));
      document.querySelectorAll('.dropdown-trigger').forEach((t) => t.classList.remove('is-active'));
    }
  });

  // 完全適應 Astro 客戶端動態加載生命週期
  initNavigationSystem();
  document.addEventListener('astro:page-load', initNavigationSystem);
</script>