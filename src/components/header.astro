---
// src/components/header.astro
---
<header class="navbar">
  <div class="nav-container">
    <div class="nav-logo">
      <a href="/personal/" class="logo-text">Weilin Lai</a>
    </div>
    
    <nav class="nav-menu" id="navMenu">
      <div class="nav-links">
        <div class="nav-item dropdown">
          <button class="dropdown-trigger">
            projects
            <svg class="chevron-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
          
          <div class="dropdown-content">
            <a href="https://weilinlai719.github.io/personal/Taipei101" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🏮 Taipei 101 Fireworks</span>
            </a>
            <a href="https://weilinlai719.github.io/personal/tetris" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🕹️ Tetris Game</span>
            </a>
            <a href="https://weilinlai719.github.io/luckydraw" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🎁 抽獎器</span>
            </a>
            <a href="https://weilinlai719.github.io/personal/flipcard" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🃏 Flip Card (寒假單字)</span>
            </a>
            <a href="https://weilinlai719.github.io/personal/pdfreader" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">📚 PDF Reader</span>
            </a>
            <a href="https://weilinlai719.github.io/earth-science-explore/" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🌎 地科探究</span>
            </a>
          </div>
        </div>

        <a href="/personal/about/" class="nav-item nav-link">about</a>
      </div>
    </nav>
  </div>
</header>

<style> 
  .navbar {
    background: var(--header-bg, rgba(255, 255, 255, 0.85));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--shadow-color2, #e5e7eb);
    position: sticky;
    top: 0;
    z-index: 1000;
    padding: 0 20px;
    height: 4rem;
    display: flex;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
  }

  .nav-container {
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-text {
    text-decoration: none;
    color: var(--text-color, #171717);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .nav-links { 
    display: flex; 
    gap: 10px; 
    align-items: center;
  }

  .nav-item {
    text-decoration: none;
    color: var(--secondary-text-color, #6f6f6f);
    padding: 8px 16px;
    border-radius: 6px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    font-size: 0.95rem;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .nav-item:hover, .nav-item.active { 
    color: var(--text-color, #171717);
    background: var(--shadow-color2, rgba(0,0,0,0.05));
  }

  .dropdown-trigger {
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .chevron-icon {
    width: 14px;
    height: 14px;
    fill: currentColor;
    transition: transform 0.3s ease;
  }

  .dropdown-content {
    position: absolute;
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    padding: 8px;
    box-sizing: border-box;
    z-index: 99999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
  }

  .dropdown-link {
    display: block;
    color: #6f6f6f;
    padding: 12px 16px;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .link-title {
    font-size: 0.95rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .dropdown-link:hover {
    background-color: #f5f5f5;
    color: #171717;
  }

  @media screen and (min-width: 769px) {
    .dropdown {
      position: relative;
    }
    
    .dropdown-content {
      top: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(-10px);
      width: 260px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .dropdown:hover .dropdown-content {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(4px);
    }

    .dropdown:hover .chevron-icon {
      transform: rotate(180deg);
    }

    .dropdown-link:hover {
      padding-left: 20px;
    }
  }

  @media screen and (max-width: 768px) {
    .nav-container,
    .nav-links,
    .dropdown {
      position: static;
    }

    .dropdown-content {
      top: 4rem;
      left: 0;
      right: 0;
      width: 100vw;
      border-left: none;
      border-right: none;
      border-radius: 0;
      border-bottom: 2px solid #e2e8f0;
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08);
      padding: 16px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      transform: translateY(-10px);
    }

    .dropdown-content.is-active {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .dropdown-link {
      background-color: #f8fafc;
      padding: 14px 16px;
    }

    .dropdown-link:hover {
      background-color: #f1f5f9;
    }

    .link-title {
      font-size: 1rem;
      color: #1e293b;
    }

    .dropdown-trigger.is-active .chevron-icon {
      transform: rotate(180deg);
    }
  }
</style>

<script>
  // 建立模組級變數，確保安全型別與避免重疊監聽
  let activeTrigger: HTMLElement | null = null;
  let activeContent: HTMLElement | null = null;

  function handleTriggerClick(e: Event) {
    e.stopPropagation();
    if (activeContent && activeTrigger) {
      const isActive = activeContent.classList.toggle('is-active');
      activeTrigger.classList.toggle('is-active', isActive);
    }
  }

  function handleOutsideClick(e: Event) {
    if (activeContent && activeTrigger) {
      const target = e.target as Node;
      if (!activeContent.contains(target) && target !== activeTrigger) {
        activeContent.classList.remove('is-active');
        activeTrigger.classList.remove('is-active');
      }
    }
  }

  function setupMobileDropdown() {
    const trigger = document.querySelector('.dropdown-trigger') as HTMLElement | null;
    const content = document.querySelector('.dropdown-content') as HTMLElement | null;

    if (!trigger || !content) return;

    activeTrigger = trigger;
    activeContent = content;

    // 清理舊監聽器
    trigger.removeEventListener('click', handleTriggerClick);
    document.removeEventListener('click', handleOutsideClick);

    if (window.innerWidth <= 768) {
      trigger.addEventListener('click', handleTriggerClick);
      document.addEventListener('click', handleOutsideClick);
    } else {
      content.classList.remove('is-active');
      trigger.classList.remove('is-active');
    }
  }

  // 完美支持 Astro SPA 路由生命週期
  setupMobileDropdown();
  document.addEventListener('DOMContentLoaded', setupMobileDropdown);
  document.addEventListener('astro:page-load', setupMobileDropdown);
  window.addEventListener('resize', setupMobileDropdown);
</script>