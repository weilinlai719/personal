---
// src/components/header.astro
 
        const pathname = Astro.url.pathname;

// 判斷目前是否在 ? 頁面（考慮到 GitHub Pages 的 /personal/ 前綴與結尾斜線）
const isAbout = pathname.includes('/about');
const isscience = pathname.includes('/science');
const ispost = pathname.includes('/post');
---
<header class="navbar">
  <div class="nav-container">
    <div class="nav-logo">
      <a href="/personal/" class="logo-text">Weilin Lai</a>
    </div>
         
    <nav class="nav-menu" id="navMenu">
      <div class="nav-links">
        
        <a href="/personal/post/" class:list={['nav-item', 'nav-link', { active: ispost }]}>
          Posts
        </a>
        
        <div class="nav-item dropdown">
          <button 
            onclick="window.location.href='/personal/science/'" 
            class:list={['dropdown-trigger', 'nav-item', 'nav-link', { active: isscience }]}
          >
            探究實作
            <svg class="chevron-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
          
          <div class="dropdown-content">
            <a href="/personal/science/physics/" class="dropdown-link" rel="noopener noreferrer">
              <span class="link-title">物理探究</span>
            </a>
            <a href="/personal/science/chemistry/" class="dropdown-link" rel="noopener noreferrer">
              <span class="link-title">化學探究</span>
            </a>
            <a href="/personal/science/biology/" class="dropdown-link" rel="noopener noreferrer">
              <span class="link-title">生物探究</span>
            </a>
            <a href="/personal/science/earth-science/" class="dropdown-link" rel="noopener noreferrer">
              <span class="link-title">地科探究</span>
            </a>
          </div>
        </div> <div class="nav-item dropdown">
          <button class="dropdown-trigger">
            projects
            <svg class="chevron-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
          
          <div class="dropdown-content">
            <a href="https://weilinlai719.github.io/personal/Taipei101" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🏮 Taipei 101 Fireworks</span>
            </a>
            <a href="https://weilinlai719.github.io/personal/tetris" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🕹️ Tetris Game</span>
            </a>
            <a href="https://weilinlai719.github.io/luckydraw" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🎁 抽獎器</span>
            </a>
            <a href="https://weilinlai719.github.io/personal/flipcard" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🃏 Flip Card (寒假單字)</span>
            </a>
            <a href="https://weilinlai719.github.io/personal/pdfreader" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">📚 PDF Reader</span>
            </a>
            <a href="https://weilinlai719.github.io/earth-science-explore/" class="dropdown-link" target="_blank" rel="noopener noreferrer">
              <span class="link-title">🌎 地科探究</span>
            </a>
          </div>
        </div>

        <a href="/personal/about/" class:list={['nav-item', 'nav-link', { active: isAbout }]}>
          about
        </a>
        
      </div>
    </nav>
  </div>
</header>

<style> 
  .navbar {
    background: var(--header-bg, rgba(255, 255, 255, 0.65));
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--shadow-color2, #e5e7eb);
    position: sticky;
    top: 0;
    z-index: 1000;
    padding: 0 20px;
    height: 4rem;
    display: flex;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
  }

  .nav-container {
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-text {
    text-decoration: none;
    color: var(--text-color, #171717);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .nav-links { 
    display: flex; 
    gap: 10px; 
    align-items: center;
  }
  

  .nav-item {
    text-decoration: none;
    color: var(--secondary-text-color, #6f6f6f);
    padding: 8px 16px;
    border-radius: 6px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    font-size: 0.95rem;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
  }
    .nav-item.active{ 
    color: var(--text-color, #121213);
    font-weight: 500;
  }
  .nav-item:hover { 
    color: var(--text-color, #000000);
    background: var(--shadow-color2, rgba(0,0,0,0.05));
  }

  .dropdown-trigger {
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .chevron-icon {
    width: 14px;
    height: 14px;
    fill: currentColor;
    transition: transform 0.3s ease;
  }

  .dropdown-content {
    position: absolute;
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    padding: 8px;
    box-sizing: border-box;
    z-index: 99999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
  }

  .dropdown-link {
    display: block;
    color: #6f6f6f;
    padding: 12px 16px;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .link-title {
    font-size: 0.95rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .dropdown-link:hover {
    background-color: #f5f5f5;
    color: #171717;
  }

  @media screen and (min-width: 769px) {
    .dropdown {
      position: relative;
    }
    
    .dropdown-content {
      top: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(-10px);
      width: 260px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .dropdown:hover .dropdown-content {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(4px);
    }

    .dropdown:hover .chevron-icon {
      transform: rotate(180deg);
    }

    .dropdown-link:hover {
      padding-left: 20px;
    }
  }

  @media screen and (max-width: 768px) {
    .nav-container,
    .nav-links,
    .dropdown {
      position: static;
    }

    .dropdown-content {
      top: 4rem;
      left: 0;
      right: 0;
      width: 100vw;
      border-left: none;
      border-right: none;
      border-radius: 0;
      border-bottom: 2px solid #e2e8f0;
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08);
      padding: 16px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      transform: translateY(-10px);
    }

    .dropdown-content.is-active {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .dropdown-link {
      background-color: #f8fafc;
      padding: 14px 16px;
    }

    .dropdown-link:hover {
      background-color: #f1f5f9;
    }

    .link-title {
      font-size: 1rem;
      color: #1e293b;
    }

    .dropdown-trigger.is-active .chevron-icon {
      transform: rotate(180deg);
    }
  }
</style>

<script>
  // 1. 定義全域唯一的點擊處理函式
  function handleDocumentClick(e: Event) {
    const target = e.target as HTMLElement;
    
    // 尋找點擊目標是否為按鈕，或是按鈕裡面的文字/SVG 箭頭
    const trigger = target.closest('.dropdown-trigger') as HTMLElement | null;
    
    if (trigger) {
      // 如果是電腦版，交給 CSS :hover 處理，JS 直接跳出不介入
      if (window.innerWidth > 769) return;
      
      e.preventDefault();
      e.stopPropagation();
      
      const dropdown = trigger.closest('.dropdown');
      const content = dropdown?.querySelector('.dropdown-content') as HTMLElement | null;
      
      if (content) {
        // 檢查當前這個選單是不是本來就是開著的
        const isCurrentlyActive = content.classList.contains('is-active');
        
        // 【關鍵防禦】點擊任何按鈕時，先把畫面上「所有」選單（包含 navmenu1, navmenu2）全部強制關閉
        document.querySelectorAll('.dropdown-content').forEach((c) => c.classList.remove('is-active'));
        document.querySelectorAll('.dropdown-trigger').forEach((t) => t.classList.remove('is-active'));
        
        // 如果原本是關閉的，現在才把它打開（明確用 add，絕不重複觸發）
        if (!isCurrentlyActive) {
          content.classList.add('is-active');
          trigger.classList.add('is-active');
        }
      }
      return;
    }
    
    // 點擊外面時：如果點擊的地方不在任何選單 (.dropdown) 裡面，就關閉所有開著的選單
    if (!target.closest('.dropdown')) {
      document.querySelectorAll('.dropdown-content').forEach((c) => c.classList.remove('is-active'));
      document.querySelectorAll('.dropdown-trigger').forEach((t) => t.classList.remove('is-active'));
    }
  }

  // 2. 當瀏覽器視窗縮放回電腦版時，自動清空手機版的殘留狀態
  function handleResizeCleanup() {
    if (window.innerWidth > 769) {
      document.querySelectorAll('.dropdown-content').forEach((c) => c.classList.remove('is-active'));
      document.querySelectorAll('.dropdown-trigger').forEach((t) => t.classList.remove('is-active'));
    }
  }

  // 3. 核心初始化功能：控管監聽器數量，確保全域永遠只有一個監聽器
  function initDropdownSystem() {
    // 先徹底移除舊的，防止 Astro SPA 路由生命週期重複疊加
    document.removeEventListener('click', handleDocumentClick);
    window.removeEventListener('resize', handleResizeCleanup);
    
    // 重新綁定唯一的全域監聽
    document.addEventListener('click', handleDocumentClick);
    window.addEventListener('resize', handleResizeCleanup);
  }

  // 完美支援 Astro SPA 路由、首次載入與縮放
  initDropdownSystem();
  document.addEventListener('DOMContentLoaded', initDropdownSystem);
  document.addEventListener('astro:page-load', initDropdownSystem);
</script>