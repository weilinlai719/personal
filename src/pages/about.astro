---
// src/pages/about.astro
import MainLayout from '../layout/mainlayout.astro';
---

<MainLayout title="Weilin Lai - 關於">
    <div class="about-page-wrapper">
        
        <div class="about-avatar-box">
            <img 
              src="/images/avatar.jpg" 
              alt="Weilin Lai" 
              class="about-avatar" 
            />
        </div>

        <div class="about-info-text">
            <h1 class="author-name">Weilin Lai</h1>
            <p class="author-subtitle">學生 / developer</p>
            <p class="author-subtitle">-116GAST-</p>

        <div class="about-languages"style="margin-top: 0rem;">
            <span class="author-subtitle">language：</span>
            <img src="/icon/ts.svg" class="social-icon1" alt="typescript" />
            <img src="/icon/c.svg" class="social-icon1" alt="c" />
        </div>
            
            <div class="author-bio">
                <p>高中生，喜歡嘗試沒試過的東西，第一次準備學測🫠</p>
                <p>因為我們是我們，所以我們是我們。</p>
            </div>
        </div>

        <div class="about-social-networks">
            <a href="mailto:boblai719@gmail.com" class="social-button-card" title="Gmail">
                <img src="/icon/gmail.svg" class="social-icon" alt="Gmail" />
                <span class="social-text">Gmail</span>
            </a>

          <button type="button" class="social-button-card discord-copy-btn" title=" Discord ID" data-discord-id="12072880926215454869">
                <img src="/icon/discord.svg" class="social-icon" alt="Discord" />
                <span class="social-text discord-text">Discord</span>
            </button>

            <a href="https://www.instagram.com/wei_lin_lai/" target="_blank" rel="noopener noreferrer" class="social-button-card" title="Instagram">
                <img src="/icon/instagram.svg" class="social-icon" alt="Instagram" />
                <span class="social-text">Instagram</span>
            </a>
            
            <a href="https://github.com/weilinlai" target="_blank" rel="noopener noreferrer" class="social-button-card" title="GitHub">
                <img src="/icon/github.svg" class="social-icon" alt="GitHub" />
                <span class="social-text">GitHub</span>
            </a>
        </div>

    </div>
</MainLayout>

<style>
    /* 頁面主外殼排版 */
    .about-page-wrapper {
        max-width: 680px;
        margin: 4rem auto;
        padding: 0 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .about-avatar-box {
        margin-bottom: 2rem;
    }

    /* 頭像樣式 */
    .about-avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        display: block !important;
        opacity: 1 !important;
        visibility: visible !important;
        box-shadow: 0 4px 12px var(--shadow-color2, rgba(0, 0, 0, 0.05));
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    }

    .about-avatar:hover {
        transform: scale(1.08);
        box-shadow: 0 8px 20px var(--shadow-color1, rgba(0, 0, 0, 0.1));
    }

    /* 文字設定 */
    .author-name {
        font-size: 1.8rem;
        font-weight: 600;
        color: var(--text-color, #171717);
        margin-bottom: 0.6rem;
        letter-spacing: 0.5px;
    }

    .author-subtitle {
        font-size: 0.95rem;
        color: var(--secondary-text-color, #6f6f6f);
       
    }

    .author-bio {
         margin-top: 2.5rem;
        font-size: 0.95rem;
        color: var(--text-color, #171717);
        line-height: 1.8;
        margin-bottom: 3rem;
    }
    .author-bio p {
        margin-bottom: 0.3rem;
    }

    /* 社群按鈕外層容器 */
    .about-social-networks {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap; 
        gap: 1rem; 
        width: 100%;
        max-width: 600px; 
        margin-top: 1rem;
    }

    /* 打造卡片式鈕扣 */
    .social-button-card {
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem; 
        padding: 0.6rem 1.2rem;
        min-width: 130px; 
        
        /* 🛠️ 新增：重設 button 的預設樣式，讓它長得跟 a 標籤一模一樣 */
        font-family: inherit;
        cursor: pointer;
        
        background-color: var(--main-color, #f4f6f9); 
        border: 1px solid var(--shadow-color2, #e5e7eb); 
        border-radius: 10px; 
        
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 2px 4px var(--shadow-color2, rgba(0, 0, 0, 0.02));
    }

    /* 精心調校的 Hover 懸停互動效果 */
    .social-button-card:hover {
        background-color: var(--shadow-color2, #e5e7eb);
        border-color: var(--secondary-text-color, #9ca3af);
        transform: translateY(-3px);
        box-shadow: 0 6px 16px var(--shadow-color1, rgba(0, 0, 0, 0.08));
    }

    /* 圖標尺寸與填色控制 */
    .social-icon {
        width: 20px;
        height: 20px;
        object-fit: contain; 
        transition: transform 0.25s ease;
    }
   /* 專屬語言欄位的排版 */
    .about-languages {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;       /* 控制文字與圖標、圖標與圖標之間的微小間距（可自由調整，例如 6px~8px） */
        margin-top: 0.5rem; /* 調整與上方 -116GAST- 的距離 */
    }

    /* 確保圖片微調對齊文字 */
    .social-icon1 {
        width: 20px;
        height: 20px;
        object-fit: contain;
        display: inline-block;
        vertical-align: middle;
    }

    /* 按鈕文字樣式 */
    .social-text {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--secondary-text-color, #6f6f6f);
        transition: color 0.25s ease;
    }

    /* 懸停動態感 */
    .social-button-card:hover .social-icon {
        transform: scale(1.1);
    }
    .social-button-card:hover .social-text {
        color: var(--text-color, #171717);
    }
    
  /* 📱 專屬手機版的防禦性排版修復 */
@media (max-width: 768px) {
  header, .navbar {
    position: relative;
    z-index: 1000;
    background-color: #ffffff; 
  }

  .dropdown-content.grid-container {
    position: absolute;
    top: 100%;
    right: 5vw; 
    left: 5vw;  
    width: 90vw !important;
    min-width: 0 !important;
    max-width: none !important;
    grid-template-columns: 1fr !important; 
    gap: 8px !important;
    background-color: #ffffff !important;
    z-index: 9999 !important; 
    padding: 16px !important;
    border-radius: 12px !important;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15) !important;
    border: 1px solid #e5e7eb !important; 
    max-height: 70vh;
    overflow-y: auto;
  }

  .dropdown-link {
    display: flex !important;
    align-items: center;
    padding: 12px 16px !important; 
    background-color: #f9fafb; 
    border-radius: 8px;
    white-space: nowrap; 
  }
}
</style>
<script>
function setupDiscordCopy() {
    const discordBtn = document.querySelector('.discord-copy-btn') as HTMLButtonElement | null;
    const discordText = document.querySelector('.discord-text') as HTMLSpanElement | null;

    if (discordBtn && discordText) {
      discordBtn.addEventListener('click', async () => {
        // 使用空值合併運算子，確保獲取到的是字串而非 null
        const discordId = discordBtn.getAttribute('data-discord-id') ?? 'weilinlai719';
        
        try {
          await navigator.clipboard.writeText(discordId);
          
          const originalText = 'Discord';
          discordText.textContent = '已複製 ID !';
          discordText.style.color = '#10b981'; 
          
          setTimeout(() => {
            discordText.textContent = originalText;
            discordText.style.color = ''; 
          }, 2000);
          
        } catch (err) {
          alert('複製失敗，請手動複製 ID: ' + discordId);
        }
      });
    }
  }

  setupDiscordCopy();
  document.addEventListener('DOMContentLoaded', setupDiscordCopy);
  document.addEventListener('astro:page-load', setupDiscordCopy);
</script>