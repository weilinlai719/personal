---
// src/pages/article/[name].astro
import MainLayout from '../../layout/mainlayout.astro';
// 💡 Astro 5+ 新增了 render 函數來渲染 Markdown
import { getEntry, render } from 'astro:content';

export const prerender = false;

const { name } = Astro.params;

if (!name) {
  return Astro.redirect('/404');
}

// 🎯 透過 name (也就是 md 的檔名 id) 撈取文章
const entry = await getEntry('article', name);

if (!entry) {
  return Astro.redirect('/404');
}

// 💡 Astro 5+ 標準渲染方式：改用 render(entry)
const { Content } = await render(entry);
const { title, date, subject } = entry.data;
---

<MainLayout title={`Weilin Lai - ${title}`}>
  <div class="detail-container">
    <a href="/article/" class="back-btn">
      <span class="back-arrow">←</span> 返回列表
    </a>

    <article class="article-post-card">
      <header class="article-header">
        <div class="title-wrapper">
          <div class="orange-bar"></div>
          <h1 class="article-main-title">{title}</h1>
        </div>
        
        <div class="meta-wrapper">
          {date && <span class="meta-pill">📅 {date}</span>}
          {subject && <span class="meta-pill">{subject}</span>}
        </div>
      </header>

      <div class="markdown-body">
        <Content />
      </div>
    </article>
  </div>
</MainLayout>

<style is:global>
  /* 此處完全保留原本的 CSS 樣式 ... */
  .detail-container { max-width: 850px; margin: 40px auto; padding: 0 24px; box-sizing: border-box; }
  .back-btn { display: inline-flex; align-items: center; gap: 8px; text-decoration: none; color: #6f6f6f; font-weight: 500; margin-bottom: 24px; transition: color 0.2s; }
  .back-btn:hover { color: #171717; }
  .article-post-card { background: #ffffff; border-radius: 16px; border: 1px solid #f0ede9; padding: 32px; box-shadow: 0 4px 12px rgba(160, 140, 130, 0.03); }
  .title-wrapper { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; }
  .orange-bar { width: 4px; height: 32px; background-color: #ff7a00; border-radius: 2px; flex-shrink: 0; }
  .article-main-title { font-size: 1.8rem; color: #2c3e50; margin: 0; font-weight: 700; line-height: 1.4; }
  .meta-wrapper { display: flex; gap: 12px; margin-bottom: 32px; }
  .meta-pill { background: #f5f5f7; padding: 6px 12px; border-radius: 20px; font-size: 0.85rem; color: #64748b; }
  .markdown-body { color: #334155; line-height: 1.8; font-size: 1.05rem; }
  .markdown-body h2 { font-size: 1.4rem; color: #1e293b; margin-top: 36px; margin-bottom: 16px; font-weight: 600; border-bottom: 1px solid #f1f5f9; padding-bottom: 8px; }
  .markdown-body p { margin-bottom: 16px; }
  .markdown-body ul, .markdown-body ol { padding-left: 24px; margin-bottom: 16px; }
  .markdown-body li { margin-bottom: 6px; }

  /* ================= 📝 Markdown 內文精緻排版 ================= */
.markdown-body {
  color: #334155;          /* 深灰文字，比純黑更溫和 */
  line-height: 1.8;        /* 舒適的行高 */
  font-size: 1.05rem;
}

/* 標題二：## 你的標題 */
.markdown-body h2 {
  font-size: 1.45rem;
  color: #1e293b;
  margin-top: 36px;
  margin-bottom: 16px;
  font-weight: 600;
  border-bottom: 2px solid #f1f5f9; /* 下方淡淡的分割線 */
  padding-bottom: 8px;
}

/* 標題三：### 你的次標題 */
.markdown-body h3 {
  font-size: 1.2rem;
  color: #334155;
  margin-top: 28px;
  margin-bottom: 12px;
  font-weight: 600;
}

/* 段落文字：一般內文 */
.markdown-body p {
  margin-bottom: 20px;
  text-align: justify;     /* 文字左右對齊 */
}

/* 強調粗體：**粗體字** */
.markdown-body strong {
  color: #6a1919;          /* 讓粗體字自動帶上你的主題經典橘色 */
  font-weight: 600;
}

/* 無序列表：- 項目 */
.markdown-body ul {
  list-style-type: disc;
  padding-left: 24px;
  margin-bottom: 20px;
}

/* 有序列表：1. 項目 */
.markdown-body ol {
  list-style-type: decimal;
  padding-left: 24px;
  margin-bottom: 20px;
}

.markdown-body li {
  margin-bottom: 8px;
}

/* 程式碼區塊或行內代碼：`code` */
.markdown-body code {
  background: #d8dce0;
  color: #000000;
  padding: 2px 6px;
  border-radius: 4px;
  font-family: monospace;
  font-size: 0.9em;
  margin: 0 4px;
}

/* 引用區塊：> 這是引用 */
.markdown-body blockquote {
  margin: 20px 0;
  padding: 12px 20px;
  background-color: #faf9f6;
  border-left: 4px solid #ff7a00; /* 左側橘色質感邊框 */
  color: #0b203e;
  border-radius: 0 8px 8px 0;
}
</style>