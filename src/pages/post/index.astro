---
// src/pages/post/index.astro
import MainLayout from '../../layout/mainlayout.astro';
---

<MainLayout title="Weilin Lai - 討論區">
  <div class="board-container">
    <h1 class="page-title">💬 Posts</h1>

    <div id="posts-container" class="posts-list">
      <div class="loading-text">載入貼文中，請稍候...</div>
    </div>
  </div>
</MainLayout>

<style is:global>
  /* 基礎重設，防止與外層 Layout 衝突 */
  .board-container *, .board-container *::before, .board-container *::after {
    box-sizing: border-box;
  }

  .board-container {
    max-width: 850px; 
    margin: 40px auto; 
    padding: 0 24px;
  }

  .page-title {
    font-size: 1.8rem;
    color: #2c3e50;
    margin-bottom: 32px;
    font-weight: 700;
  }

  /* 貼文列表外層 */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .loading-text {
    text-align: center;
    color: #888;
    padding: 40px 0;
    font-size: 1.05rem;
  }

  /* 🌸 NixOS 網誌風卡片框框 */
  .post-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-card { 
    background: #ffffff; 
    border-radius: 20px; /* 優雅的大圓角 */
    box-shadow: 0 8px 24px rgba(160, 140, 130, 0.06); 
    border: 1px solid #f0ede9; 
    display: flex; 
    align-items: center; 
    justify-content: space-between;
    padding: 24px 24px 24px 32px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(160, 140, 130, 0.12);
  }

  /* 當卡片有圖片時，將內襯歸零讓圖片完美貼邊 */
  .post-card.has-image {
    padding: 0 0 0 32px; 
  }

  /* 左側文字主體區 */
  .card-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px; 
    min-width: 0; /* 防止文字爆開 */
  }

  /* 當有圖片時，補回文字區的上下內襯 */
  .post-card.has-image .card-left {
    padding: 24px 24px 24px 0;
  }

  /* 標題列：包含橘色立柱與發文者名字 */
  .title-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* 左側經典橘色垂直小立柱 */
  .orange-bar {
    width: 4px;
    height: 22px;
    background-color: #e67e22;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .post-author {
    font-size: 1.4rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
    line-height: 1.2;
  }

  /* 時間與 ID 小標籤列 */
  .meta-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: #fdf5ee; 
    color: #b87333; 
    padding: 4px 12px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  /* 貼文內文 */
  .post-body {
    font-size: 1.05rem;
    color: #475569;
    margin: 0;
    line-height: 1.6;
    word-break: break-all;
    white-space: pre-wrap; 
  }

  /* 底部標籤 */
  .tag-wrapper {
    display: flex;
  }

  .hash-tag {
    background-color: #f1f5f9;
    color: #64748b;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* 🖼️ 右側精緻圖片裁切殼 */
  .card-img-wrapper {
    width: 260px; 
    align-self: stretch; 
    flex-shrink: 0; 
  }

  .card-side-img {
    width: 100%;
    height: 100%;
    object-fit: cover; 
    display: block;
  }

  /* ➡️ 右側獨立箭頭區塊 */
  .card-right-arrow {
    width: 46px;
    height: 90px; 
    background-color: #fdf5ee; 
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: 24px;
    flex-shrink: 0; 
    transition: background-color 0.2s;
  }

  /* 當有圖片時，讓右側箭頭絕對定位浮動在桌機版右側 */
  .post-card.has-image .card-right-arrow {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    margin-left: 0;
    z-index: 2;
    background-color: rgba(253, 245, 238, 0.9); 
    box-shadow: 0 4px 12px rgba(184, 115, 51, 0.15);
  }

  .post-card:hover .card-right-arrow {
    background-color: #fbe6d4; 
  }

  /* 純 CSS 繪製精緻箭頭 > */
  .arrow-shape {
    border: solid #b87333;
    border-width: 0 2.5px 2.5px 0;
    display: inline-block;
    padding: 4px;
    transform: rotate(-45deg);
  }

  /* =======================================================
     📱 核心拯救：手機版 RWD 響應式佈局彈性調整 (螢幕寬度 768px 以下)
     ======================================================= */
  @media (max-width: 768px) {
    .board-container {
      margin: 20px auto;
      padding: 0 16px;
    }

    .page-title {
      font-size: 1.5rem;
      margin-bottom: 20px;
    }

    /* 1. 當有圖片時，手機版強制轉為「上下堆疊」排版，絕不壓扁文字 */
    .post-card.has-image {
      flex-direction: column;
      align-items: stretch;
      padding: 0 0 16px 0; /* 圖片塞滿上方，下方文字留白 */
    }

    /* 2. 有圖片時，下方文字主體的內襯間距修正 */
    .post-card.has-image .card-left {
      padding: 20px 20px 0 20px;
    }

    /* 3. 圖片外殼在手機版變成完美的上方橫幅 (Banner) */
    .card-img-wrapper {
      width: 100% !important;
      height: 180px; /* 給予固定高度，寬度隨螢幕自動伸展 */
      order: -1; /* 透過 flex 屬性，魔法般的將圖片提到最上方展示 */
    }

    /* 4. 有圖片時的右側箭頭：移出絕對定位，轉為右下角精緻的圓形鈕 */
    .post-card.has-image .card-right-arrow {
      position: relative;
      right: auto;
      top: auto;
      transform: none;
      margin: 12px 20px 0 auto; /* 自動推至右下角 */
      width: 36px;
      height: 36px;
      border-radius: 50%; /* 變成漂亮的圓形小雷達 */
      box-shadow: 0 2px 8px rgba(184, 115, 51, 0.1);
    }

    /* 5. 無圖片時的純文字卡片箭頭稍微矮一點點，讓排版更精緻 */
    .card-right-arrow {
      height: 70px;
      margin-left: 12px;
    }
  }
</style>

<script>
  const API_BASE_URL = 'https://words7000.onrender.com';
  const postsContainer = document.getElementById('posts-container') as HTMLElement | null;

  async function fetchAllPosts() {
    if (!postsContainer) return;
    try {
      const res = await fetch(`${API_BASE_URL}/api/posts`);
      const data = await res.json();
      if (data.success && data.posts.length > 0) {
        const reversedPosts = data.posts.reverse();
        postsContainer.innerHTML = reversedPosts.map((post: any) => {
          const dateStr = post.time;

          // 檢查有無圖片
          const hasImg = !!post.image;
          const cardClass = hasImg ? 'post-card has-image' : 'post-card';
          const imgHtml = hasImg 
            ? `<div class="card-img-wrapper"><img src="${post.image}" class="card-side-img" alt="貼文圖片" onerror="this.parentNode.style.display='none'"/></div>` 
            : '';
          const idHtml = post.id ? `<span class="meta-pill"> ${post.id}</span>` : '';
          return `
            <a href="/post/${post.id}" class="post-card-link">
              <div class="${cardClass}">
                
                <div class="card-left">
                  <div class="title-wrapper">
                    <div class="orange-bar"></div>
                    <h2 class="post-author">${post.name || '匿名訪客'}</h2>
                  </div>
                  
                  <div class="meta-wrapper">
                    <span class="meta-pill">📅 ${dateStr}</span>
                    ${idHtml}

                    <span class="meta-pill"> ${post.id}</span>
                  </div>
                  
                  <p class="post-body">${post.content || '點擊查看詳細內容...'}</p>
                  
                  <div class="tag-wrapper">
                    <span class="hash-tag"># posts</span>
                  </div>
                </div>
                
                ${imgHtml}
                
                
                <div class="card-right-arrow">
                  <i class="arrow-shape"></i>
                </div>

              </div>
            </a>
          `;
        }).join('');
      } else {
        postsContainer.innerHTML = `<div class="loading-text">目前尚未有任何動態</div>`;
      }
    } catch (err) {
      postsContainer.innerHTML = `<div class="loading-text" style="color: #ef4444;">無法連線至伺服器，請稍後再試。</div>`;
      console.error('Fetch posts error:', err);
    }
  }

  fetchAllPosts();
</script>