---
// src/pages/post/index.astro
import MainLayout from '../../layout/mainlayout.astro';
---

<MainLayout title="Weilin Lai - 討論區">
  <div class="board-container">
    <h1 class="page-title">💬 Posts</h1>

    <div id="posts-container" class="posts-list">
      <div class="loading-text">載入貼文中，請稍候...</div>
    </div>
  </div>
</MainLayout>

<style is:global>
  /* 基礎重設，防止與外層 Layout 衝突 */
  .board-container *, .board-container *::before, .board-container *::after {
    box-sizing: border-box;
  }



  .board-container {
    max-width: 850px; 
    margin: 40px auto; 
    padding: 0 24px;
  }

  .page-title {
    font-size: 1.8rem;
    color: #2c3e50;
    margin-bottom: 32px;
    font-weight: 700;
  }

  /* 貼文列表外層，用 gap 撐開每則卡片，絕不碰撞 */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 24px; 
  }

  .loading-text {
    text-align: center;
    color: #888;
    padding: 40px 0;
    font-size: 1.05rem;
  }

  /* 🌸 完美還原：NixOS 網誌風卡片框框 */
  .post-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-card { 
    background: #ffffff; 
    border-radius: 20px; /* 優雅的大圓角 */
    box-shadow: 0 8px 24px rgba(160, 140, 130, 0.06); /* 輕盈質感的微光陰影 */
    border: 1px solid #f0ede9; 
    display: flex; 
    align-items: center; /* 讓左右兩邊垂直置中對齊 */
    justify-content: space-between;
    padding: 24px 24px 24px 32px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(160, 140, 130, 0.12);
  }

  /* 左側文字主體區 */
  .card-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px; /* 嚴格限制內部元件間距，絕不重疊卡到 */
    min-width: 0; /* 防止文字爆開 */
  }

  /* 標題列：包含橘色立柱與發文者名字 */
  .title-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* 左側經典橘色垂直小立柱 */
  .orange-bar {
    width: 4px;
    height: 22px;
    background-color: #e67e22;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .post-author {
    font-size: 1.4rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
    line-height: 1.2;
  }

  /* 時間與 ID 小標籤列 */
  .meta-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* 質感小膠囊標籤 */
  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: #fdf5ee; /* 淡淡的暖橘色底 */
    color: #b87333; /* 焦糖棕色字 */
    padding: 4px 12px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  /* 貼文內文 */
  .post-body {
    font-size: 1.05rem;
    color: #475569;
    margin: 0;
    line-height: 1.6;
    word-break: break-all;
    white-space: pre-wrap; /* 保留換行換氣 */
    
  }

  /* 底部標籤 */
  .tag-wrapper {
    display: flex;
  }

  .hash-tag {
    background-color: #f1f5f9;
    color: #64748b;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* ➡️ 右側內嵌入格子的獨立箭頭區塊 */
  .card-right-arrow {
    width: 46px;
    height: 90px; /* 固定高度的右側長條膠囊 */
    background-color: #fdf5ee; 
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: 24px;
    flex-shrink: 0; /* 絕對不允許被壓縮擠扁 */
    transition: background-color 0.2s;
  }

  .post-card:hover .card-right-arrow {
    background-color: #fbe6d4; /* 滑過時顏色稍微加深 */
  }

  /* 純 CSS 繪製精緻箭頭 > */
  .arrow-shape {
    border: solid #b87333;
    border-width: 0 2.5px 2.5px 0;
    display: inline-block;
    padding: 4px;
    transform: rotate(-45deg);
  }

</style>

<script>
  const API_BASE_URL = 'https://words7000.onrender.com';

  const postsContainer = document.getElementById('posts-container') as HTMLElement | null;
  // 非同步抓取所有貼文並渲染
  async function fetchAllPosts() {
    if (!postsContainer) return;

    try {
      const res = await fetch(`${API_BASE_URL}/api/posts`);
      const data = await res.json();

      if (data.success && data.posts.length > 0) {
        const reversedPosts = data.posts.reverse();

        postsContainer.innerHTML = reversedPosts.map((post: any) => {
                    const dateStr = post.time  ;

          return `
            <a href="/post/${post.id}" class="post-card-link">
              <div class="post-card">
                
                <div class="card-left">
                  <div class="title-wrapper">
                    <div class="orange-bar"></div>
                    <h2 class="post-author">${post.name || '匿名訪客'}</h2>
                  </div>
                  
                  <div class="meta-wrapper">
                    <span class="meta-pill">📅 ${dateStr}</span>
                    <span class="meta-pill"> ID: ${post.id}</span>
                  </div>
                  
                  <p class="post-body">${post.content || '點擊查看詳細內容...'}</p>
                  
                  <div class="tag-wrapper">
                    <span class="hash-tag"># 討論區動態</span>
                  </div>
                </div>
                
                <div class="card-right-arrow">
                  <i class="arrow-shape"></i>
                </div>

              </div>
            </a>
          `;
        }).join('');
      } else {
        postsContainer.innerHTML = `<div class="loading-text">目前尚未有任何動態</div>`;
      }
    } catch (err) {
      postsContainer.innerHTML = `<div class="loading-text" style="color: #ef4444;">無法連線至伺服器，請稍後再試。</div>`;
      console.error('Fetch posts error:', err);
    }
  }

  

  fetchAllPosts();
</script>