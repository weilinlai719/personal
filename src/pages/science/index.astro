---
// science/index.astro
import MainLayout from '../../layout/mainlayout.astro';
---

<MainLayout title="Weilin Lai - 自然科學探究">
  <div class="science-archive-container">
    <h1 class="page-title">自然科學探究與實作</h1>
    
    <div class="science-cards-grid">
    
    <a href="/personal/science/physics" class="science-card-link">
      <div class="custom-science-card">
        <div class="card-left-content">
          <div class="card-top-meta">
            <span class="card-date">📅 2026年6月</span>
          </div>
          <h2 class="card-main-title">物理探究：紙飛機不同配重分布下飛行｢狀態/距離｣之關係</h2>
          <div class="card-bottom-actions">
            <span class="more-pill-btn">more...</span>
            <span class="subject-tag">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
              物理
            </span>
          </div>
        </div>
        <div class="card-right-image bg-physics">
          </div>
      </div>
    </a>

    <a href="/personal/science/chemistry" class="science-card-link">
      <div class="custom-science-card">
        <div class="card-left-content">
          <div class="card-top-meta">
            <span class="card-date">📅 2026年1月</span>
          </div>
          <h2 class="card-main-title">化學探究：校園各種水源pH值比較</h2>
          <div class="card-bottom-actions">
            <span class="more-pill-btn">more...</span>
            <span class="subject-tag">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
              化學
            </span>
          </div>
        </div>
        <div class="card-right-image bg-chemistry">
          </div>
      </div>
    </a>

    <a href="/personal/science/biology" class="science-card-link">
      <div class="custom-science-card">
        <div class="card-left-content">
          <div class="card-top-meta">
            <span class="card-date">📅 2025年11月</span>
          </div>
          <h2 class="card-main-title">生物探究：:DNA粗萃取與清潔劑濃度關係之探討 </h2>
          <div class="card-bottom-actions">
            <span class="more-pill-btn">more...</span>
            <span class="subject-tag">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
              生物
            </span>
          </div>
        </div>
        <div class="card-right-image bg-biology">
          </div>
      </div>
    </a>

    <a href="/personal/science/earth-science" class="science-card-link">
      <div class="custom-science-card">
        <div class="card-left-content">
          <div class="card-top-meta">
            <span class="card-date">📅 2026年3月</span>
          </div>
          <h2 class="card-main-title">地球科學：聖嬰與反聖嬰之下台灣區域海氣溫度變異之影響</h2>
          <div class="card-bottom-actions">
            <span class="more-pill-btn">more...</span>
            <span class="subject-tag">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
              地科
            </span>
          </div>
        </div>
        <div class="card-right-image bg-earth">
          </div>
      </div>
    </a>

  </div>
</div>
</MainLayout>
<style>
  /* 全域容器：對齊你的 60% 網頁核心寬度 */
  .science-archive-container {
    width: 60%;
    margin: 4rem auto;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .page-title {
    font-size: 1.75rem;
    color: #0f172a;
    margin-bottom: 2rem;
    font-weight: 700;
    border-left: 5px solid #f43f5e;
    padding-left: 12px;
  }

  /* 列表排版 */
  .science-cards-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* 移除超連結預設底線 */
  .science-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  /* 💡 核心：復刻截圖外觀的卡片主體 */
  .custom-science-card {
    display: flex;
    background-color: #ffffff;
    border-radius: 12px;
    min-height: 180px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    border: 1px solid #e2e8f0;
    overflow: hidden;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  /* 滑鼠懸停骨感動畫 */
  .custom-science-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  }

  /* 左側內容排版 */
  .card-left-content {
    flex: 1;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    z-index: 2; /* 確保內容在斜切面之上 */
    background-color: #ffffff;
  }

  .card-top-meta {
    color: #94a3b8;
    font-size: 0.85rem;
    margin-bottom: 8px;
  }

  .card-main-title {
    color: #1e3a8a; /* 精緻的藍色標題 */
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
    margin-bottom: 16px;
    /* 限制兩行，超出顯示點點點 */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 底部按鈕與標籤容器 */
  .card-bottom-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  /* 💡 精密復刻：左下角 more... 漸層按鈕 */
  .more-pill-btn {
    background: linear-gradient(135deg, #ff7e5f, #feb47b, #ff7e5f);
    background-size: 200% auto;
    color: white;
    font-size: 0.8rem;
    font-weight: bold;
    padding: 6px 16px;
    border-radius: 20px 8px 8px 20px; /* 仿截圖的不對稱微圓角，或直接用 20px */
    box-shadow: 0 4px 10px rgba(255, 126, 95, 0.2);
    transition: background-position 0.3s;
  }

  .custom-science-card:hover .more-pill-btn {
    background-position: right center; /* 懸停時漸層流動效果 */
  }

  /* 右下角主題標籤 */
  .subject-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: #64748b;
    font-size: 0.85rem;
  }

  /* 💡 核心：右側斜切圖片區 (利用 clip-path 達成完美斜切) */
  .card-right-image {
    width: 40%;
    position: relative;
    /* clip-path 的四個點座標：右上、右下、左下、左上 */
    /* 這裡讓左上點往右縮進 (20% 0)，左下點靠最左 (0% 100%)，達成由上往左下的斜線 */
    clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%);
    margin-left: -5%; /* 讓斜切面自然咬合左側白底 */
    overflow: hidden;
  }

  /* 確保未來塞入的圖片能填滿並完美適應 */
  .card-right-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 🎨 暫時擱置圖片時的優雅幾何漸層色塊 */
  .bg-physics { background: linear-gradient(135deg, #6ee7b7, #3b82f6); }
  .bg-chemistry { background: linear-gradient(135deg, #fcd34d, #f97316); }
  .bg-biology { background: linear-gradient(135deg, #a7f3d0, #059669); }
  .bg-earth { background: linear-gradient(135deg, #c084fc, #6366f1); }


  /* 📱 響應式優化：手機版自動改為上下堆疊，並取消斜切 */
  @media screen and (max-width: 768px) {
    .science-archive-container {
      width: 92%;
      margin: 2rem auto;
    }
    .custom-science-card {
      flex-direction: column-reverse; /* 手機版圖片在上方，內容在下方 */
    }
    .card-right-image {
      width: 100%;
      height: 120px;
      clip-path: none; /* 關閉斜切，回歸正常方塊 */
      margin-left: 0;
    }
    .card-main-title {
      font-size: 1.15rem;
    }
  }
</style>